# ── App
APP_NAME="Logistics Platform"
APP_ENV=development          # development | staging | production
DEBUG=true
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
API_V1_PREFIX=/api/v1

# ── Database
DATABASE_URL=postgresql+asyncpg://logistics:123456@localhost:5432/logistics_db
DATABASE_URL_SYNC=postgresql+psycopg2://logistics:123456@localhost:5432/logistics_db

# ── Redis
REDIS_URL=redis://localhost:6379/0

# ── Auth / JWT
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256
TOTP_ISSUER=LogisticsPlatform

# ── AWS S3 / MinIO
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1
S3_BUCKET=logistics-docs
S3_ENDPOINT_URL=http://localhost:9000   # remove for real AWS

# ── Email (SendGrid)
SENDGRID_API_KEY=SG.xxxxxxxxxxxx
DEFAULT_FROM_EMAIL=noreply@yourcompany.com

# ── SMS (Twilio)
TWILIO_ACCOUNT_SID=ACxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxx
TWILIO_FROM_NUMBER=+971xxxxxxx

# ── Firebase (push notifications)
FIREBASE_CREDENTIALS_JSON=./firebase-credentials.json

# ── UAE / Company
DEFAULT_CURRENCY=AED
DEFAULT_VAT_RATE=0.05
COMPANY_COUNTRY=AE
FTA_TRN=100123456700003          # Federal Tax Authority TRN

# ── Pagination
DEFAULT_PAGE_SIZE=25
MAX_PAGE_SIZE=200

# ── CORS
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]
